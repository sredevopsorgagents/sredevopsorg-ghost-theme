<footer class="mt-16 pt-8 border-t border-gray-800 pb-12">

  {{!-- Secondary Navigation (Footer Links) --}}
  {{#if @site.secondary_navigation}}
  <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-6 text-sm font-medium text-gray-400">
    {{navigation type="secondary"}}
  </div>
  {{else}}
  {{!-- Fallback links if no secondary navigation is set in Ghost Admin --}}
  <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-6 text-sm font-medium text-gray-500">
    <a href="#" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
    <a href="#" class="hover:text-gray-300 transition-colors">Terms of Service</a>
    <a href="#" class="hover:text-gray-300 transition-colors">Contact</a>
  </div>
  {{/if}}

  {{!-- Copyright --}}
  <div class="text-center text-xs text-gray-600 pt-4 border-t border-gray-800/50">
    &copy; {{date format="YYYY"}} {{@site.title}}. Built with Ghost.
  </div>
</footer>