{{#is "post"}}
<div class="border border-gray-700 rounded-lg p-5 bg-dark-card sticky-top">
  <h4 class="text-white font-bold text-sm tracking-wider uppercase border-b border-gray-700 pb-2 mb-3">Table of Contents
  </h4>
  <div id="toc-container" class="js-toc"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Allow a brief moment for Ghost content to fully render in DOM
    setTimeout(function () {
      if (window.tocbot) {
        tocbot.init({
          // Where to render the table of contents
          tocSelector: '.js-toc',
          // Where to grab the headings from (your main post body)
          contentSelector: '.gh-content',
          // Which headings to grab (h2 and h3 are usually best for reading flow)
          headingSelector: 'h2, h3',
          // Optional: Enable smooth scrolling, collapse nested lists, etc.
          orderedList: false,
          collapseDepth: 6,
          scrollSmooth: true,
          scrollSmoothDuration: 400,
          headingsOffset: 80 // Adjust this based on your sticky header height
        });
      }
    }, 500);
  });
</script>
{{/is}}

<div>
  <div class="flex gap-2">
    {{> "social-share"}}
  </div>
</div>

<div class="border border-gray-700/70 rounded-lg p-6 bg-dark-card text-center shadow-lg">
  <h4 class="text-white text-lg font-bold mb-1">{{t "Stay in the loop"}}</h4>
  <p class="text-gray-400 text-xs mb-4">{{t "Get the latest posts delivered right to your inbox"}}</p>
  <div class="space-y-3">
    <div class="flex flex-col gap-2">
      <form data-members-form=>
        <input type="email" required data-members-email class="w-full bg-dark-bg border border-gray-700 rounded-md py-2 px-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-brand-purple focus:ring-1 focus:ring-brand-purple transition-all">
        <button type="submit" class="w-full bg-brand-purple hover:bg-blue-500 text-white font-semibold py-2 rounded-md text-sm transition-colors">Subscribe</button>
      </form>
    </div>
    {{!-- <a href="#" class="text-gray-500 text-[10px] hover:text-gray-300 transition-colors block mt-1">Skip for now</a> --}}
  </div>
</div>