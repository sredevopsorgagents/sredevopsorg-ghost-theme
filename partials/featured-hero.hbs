{{!-- Featured Post Hero — shown at the top of page 1 only. --}}
{{!-- Usage: {{> "featured-hero" tag="en"}} — tag scopes the featured post to the current locale. --}}
{{^is "paged"}}
{{#get "posts" filter="featured:true+tag:{{tag}}" limit="1" include="authors,tags" as |featuredPosts|}}
{{#foreach featuredPosts}}
<a href="{{url}}"
    class="group block mb-12 rounded-2xl overflow-hidden border border-gray-800 bg-dark-card hover:border-brand-purple transition-colors">
    <div class="grid grid-cols-1 lg:grid-cols-2">
        {{#if feature_image}}
        <div class="aspect-[16/9] lg:aspect-auto overflow-hidden">
            <img src="{{img_url feature_image size="xl"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
        </div>
        {{/if}}
        <div class="p-6 md:p-8 flex flex-col justify-center">
            <span class="text-xs font-bold text-brand-purple uppercase tracking-wider mb-3 font-mono">Featured</span>
            {{#if primary_tag}}
            <span class="text-xs text-gray-500 uppercase tracking-wider mb-2">{{primary_tag.name}}</span>
            {{/if}}
            <h2
                class="text-2xl md:text-3xl font-bold text-white group-hover:text-brand-purple transition-colors leading-tight mb-3">
                {{title}}</h2>
            <p class="text-sm text-gray-400 line-clamp-3 mb-4">{{excerpt words="30"}}</p>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
                {{#foreach authors limit="1"}}<span>{{name}}</span>{{/foreach}}
                <span>&middot;</span>
                <span>{{date published_at format="MMM d, YYYY"}}</span>
                <span>&middot;</span>
                <span>{{reading_time minute=(t "Just a minute or less") minutes=(t "About % minutes read")}}</span>
            </div>
        </div>
    </div>
</a>
{{/foreach}}
{{/get}}
{{/is}}
