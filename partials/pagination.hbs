<nav class="pagination flex flex-wrap justify-center items-center gap-3 py-4" role="navigation">
    {{#if prev}}
    <a class="pagination-link inline-flex items-center justify-center rounded-full border border-white/20 bg-brand-purple px-4 py-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white transition hover:bg-white/10 hover:text-white" href="{{page_url prev}}">
        {{t "Newer Posts"}}
    </a>
    {{/if}}
    <span class="pagination-page">{{t "Page"}} {{page}} {{t "of"}} {{pages}}</span>
    {{#if next}}
    <a class="pagination-link inline-flex items-center justify-center rounded-full border border-white/20 bg-brand-purple px-4 py-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white transition hover:bg-white/10 hover:text-white" href="{{page_url next}}">
        {{t "Older Posts"}}
    </a>
    {{/if}}
</nav>