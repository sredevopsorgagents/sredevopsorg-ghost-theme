{{!< default}}
<div class="max-w-6xl mx-auto pb-12">
    <!-- Author Box -->
    {{#author}}
    <section class="author-box">
        <div class="flex flex-col w-full p-4">
            <div class="flex items-start gap-4 mb-4">
                {{#if profile_image}}
                <img src="{{img_url profile_image size="xs" format="webp" }}" alt="{{name}}"
                    class="h-16 w-16 rounded-full object-cover border border-gray-700">
                {{/if}}
                <div class="flex-1">
                    <p class="text-white font-semibold">{{name}}</p>
                    <p class="text-xs text-brand-blue hover:underline transition-colors"><a href="{{url}}">View more content
                            by {{name}}</a></p>
                    {{#if bio}}
                    <p class="text-gray-400 text-sm mt-1">{{bio}}</p>
                    {{/if}}
                </div>
            </div>
    
            <div class="flex flex-wrap gap-2 mb-4">
                <div class="flex flex-wrap gap-2 text-sm">
                    {{#if website}}
                    <a href="{{website}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-solid fa-link"></i>
                        Website
                    </a>
                    {{/if}}
                    {{#if twitter}}
                    <a href="{{social_url type="twitter"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-twitter"></i>
                        Twitter
                    </a>
                    {{/if}}
                    {{#if facebook}}
                    <a href="{{social_url type="facebook"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-facebook"></i>
                        Facebook
                    </a>
                    {{/if}}
                    {{#if linkedin}}
                    <a href="{{social_url type="linkedin"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-linkedin-in"></i>
                        LinkedIn
                    </a>
                    {{/if}}
                    {{#if threads}}
                    <a href="{{social_url type="threads"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-threads"></i>
                        Threads
                    </a>
                    {{/if}}
                    {{#if bluesky}}
                    <a href="{{social_url type="bluesky"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-bluesky"></i>
                        Bluesky
                    </a>
                    {{/if}}
                    {{#if mastodon}}
                    <a href="{{social_url type="mastodon"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-mastodon"></i>
                        Mastodon
                    </a>
                    {{/if}}
                    {{#if tiktok}}
                    <a href="{{social_url type="tiktok"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-tiktok"></i>
                        TikTok
                    </a>
                    {{/if}}
                    {{#if youtube}}
                    <a href="{{social_url type="youtube"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-youtube"></i>
                        YouTube
                    </a>
                    {{/if}}
                    {{#if instagram}}
                    <a href="{{social_url type="instagram"}}" target="_blank" rel="noopener"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 text-sm transition-colors">
                        <i class="fa-brands fa-instagram"></i>
                        Instagram
                    </a>
                    {{/if}}
                    {{#if location}}
                    <span class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-400 text-sm">
                        <i class="fa-solid fa-location-dot"></i>
                        {{location}}
                    </span>
                    {{/if}}
                </div>
            </div>
        </div>   
    </section>
    {{/author}}
    {{!-- Post Grid --}}
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </section>

    {{!-- Pagination --}}
    {{pagination}}
</div>
