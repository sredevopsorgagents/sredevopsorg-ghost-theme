{{!< default}}
<div class="max-w-6xl mx-auto pb-12">
{{#is "tag" }}
{{#tag}}
    {{!-- Tag Name & Description --}}
    <div class="mb-10 border-b border-gray-800 pb-6">
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">{{name}}</h1>
    {{#if description}}
        <p class="text-gray-400 mt-2 text-lg">{{description}}</p>
    {{/if}}
    </div>
{{/tag}}
{{/is}}
    
    {{!-- Post Grid --}}
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </section>

    {{!-- Pagination --}}
    {{pagination}}
</div>